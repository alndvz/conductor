{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "conductor": {
      "description": "Primary agent that orchestrates workflows by delegating jobs to sub-agents",
      "mode": "primary",
      "permission": {
        "*": "allow"
      },
      "model": "opencode-go/deepseek-v4-pro",
      "tools": {
        "Task": true,
        "Bash": true,
        "Read": true,
        "Write": true,
        "Edit": true,
        "Glob": true,
        "Grep": true,
        "WebFetch": true
      }
    },
    "feature": {
      "description": "Primary agent that discusses user feature requests conversationally, with planning support before committing tasks to TASKS.md.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "tools": {
        "Task": true,
        "Bash": true,
        "Read": true,
        "Write": true,
        "Edit": true,
        "Glob": true,
        "Grep": true
      }
    },
    "implementor": {
      "description": "Sub-agent that implements tasks delegated by the conductor",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "tools": {
        "Bash": true,
        "Read": true,
        "Write": true,
        "Edit": true,
        "Glob": true,
        "Grep": true
      }
    },
    "review": {
      "description": "Sub-agent that reviews code after implementation",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "tools": {
        "Bash": true,
        "Read": true,
        "Glob": true,
        "Grep": true
      }
    },
    "rules-review": {
      "description": "Sub-agent that reviews code against project rules and conventions",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "tools": {
        "Bash": true,
        "Read": true,
        "Glob": true,
        "Grep": true
      }
    }
  },
  "plugin": []
}
